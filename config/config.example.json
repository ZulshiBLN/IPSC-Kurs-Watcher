{
  "version": 1,
  "_comment": "IPSC Kurs Watcher Configuration Example - Copy to config.json and customize",

  "monitors": [
    {
      "id": "shooting-store",
      "provider": "shooting-store",
      "enabled": true,
      "url": "https://www.shooting-store.ch/de/kategorie/kurse1",
      "base_url": "https://www.shooting-store.ch",
      "timeout_seconds": 30,
      "retry_attempts": 3,
      "poll_interval_minutes": 30
    }
  ],

  "filters": {
    "course_types": [
      {
        "id": "tryout",
        "name": "Tryout",
        "patterns": ["Tryout", "Einsteiger-Kurs"],
        "enabled": true
      },
      {
        "id": "basic",
        "name": "Basic Level",
        "patterns": ["Basic", "Anfänger", "Level 1"],
        "enabled": true
      },
      {
        "id": "basic2",
        "name": "Basic 2.0",
        "patterns": ["Basic 2.0", "Basic 2.x", "Level 2"],
        "enabled": true
      },
      {
        "id": "advanced",
        "name": "Advanced",
        "patterns": ["Advanced", "Fortgeschritten", "Level 3"],
        "enabled": true
      }
    ],
    "exclude_patterns": ["Privatunterricht", "VIP-Kurs", "Geschlossen"],
    "min_availability": 1
  },

  "notifiers": {
    "windows_toast": {
      "enabled": true,
      "sound_enabled": true,
      "group_by_type": true,
      "max_courses_per_group": 5,
      "auto_dismiss_seconds": 5,
      "main_page_url": "https://www.shooting-store.ch/de/kategorie/kurse1"
    },

    "email": {
      "enabled": false,
      "_comment_enabled": "Set to true to enable email notifications",
      "smtp_host": "smtp.gmail.com",
      "smtp_port": 587,
      "use_tls": true,
      "from_address": "your-email@gmail.com",
      "from_display_name": "IPSC Kurs Watcher",
      "smtp_user": "your-email@gmail.com",
      "smtp_password": "your-app-password",
      "_comment_password": "Gmail: Use app-specific password, not account password. Will be encrypted on first run.",
      "recipients": [
        "your-email@gmail.com",
        "friend@example.com"
      ],
      "_comment_recipients": "First recipient is primary (To:), others are BCC'd",
      "retry_attempts": 3,
      "timeout_seconds": 30,
      "template_file": "templates/email.html"
    },

    "discord": {
      "enabled": false,
      "_comment_enabled": "Set to true to enable Discord notifications",
      "webhook_urls": [
        "https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN"
      ],
      "_comment_webhook": "Get webhook URL: Right-click channel → Integrations → Webhooks → New Webhook → Copy URL",
      "mention_on_new": true,
      "_comment_mention": "Set to true to @mention user/role when new courses detected",
      "mention_user_id": null,
      "_comment_mention_user": "Discord user ID (optional, if mention_on_new=true)",
      "mention_role_id": null,
      "_comment_mention_role": "Discord role ID (optional, if mention_on_new=true)",
      "include_url_buttons": true,
      "retry_attempts": 3,
      "timeout_seconds": 30
    }
  },

  "state": {
    "file_path": "data/state.json",
    "retention_days": 30
  },

  "logging": {
    "log_dir": "data/logs",
    "log_level": "INFO",
    "retention_days": 30,
    "format": "json"
  },

  "error_handling": {
    "alert_on_repeated_errors": false,
    "error_threshold": 5,
    "error_window_minutes": 60
  }
}
