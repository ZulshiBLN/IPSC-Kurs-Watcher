{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IPSC Kurs Watcher Configuration",
  "description": "Configuration schema for IPSC course monitoring and notifications",
  "type": "object",
  "required": ["monitors", "filters", "notifiers"],
  "properties": {
    "monitors": {
      "type": "array",
      "description": "List of course monitoring sources",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "provider", "url"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique monitor identifier (alphanumeric, dash, underscore)",
            "pattern": "^[a-zA-Z0-9_-]+$"
          },
          "name": {
            "type": "string",
            "description": "Display name for this monitor"
          },
          "provider": {
            "type": "string",
            "description": "Monitor provider type",
            "enum": ["shooting-store", "generic-html"]
          },
          "url": {
            "type": "string",
            "description": "URL to monitor",
            "format": "uri"
          },
          "poll_interval_minutes": {
            "type": "integer",
            "description": "Poll interval in minutes",
            "minimum": 5,
            "default": 15
          },
          "enabled": {
            "type": "boolean",
            "description": "Enable/disable this monitor",
            "default": true
          },
          "request_timeout_seconds": {
            "type": "integer",
            "description": "HTTP request timeout",
            "minimum": 5,
            "maximum": 120,
            "default": 30
          },
          "retry_attempts": {
            "type": "integer",
            "description": "Number of retry attempts",
            "minimum": 0,
            "maximum": 5,
            "default": 3
          },
          "parser_config": {
            "type": "object",
            "description": "CSS selector configuration for HTML parsing",
            "properties": {
              "selector_course": {
                "type": "string",
                "description": "CSS selector for course elements"
              },
              "selector_title": {
                "type": "string",
                "description": "CSS selector for course title"
              },
              "selector_type": {
                "type": "string",
                "description": "CSS selector for course type"
              },
              "selector_availability": {
                "type": "string",
                "description": "CSS selector for availability/slots"
              }
            }
          }
        }
      }
    },
    "filters": {
      "type": "object",
      "description": "Course filtering configuration",
      "required": ["course_types"],
      "properties": {
        "course_types": {
          "type": "array",
          "description": "List of course types to filter",
          "items": {
            "type": "object",
            "required": ["id", "name", "patterns"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique course type identifier"
              },
              "name": {
                "type": "string",
                "description": "Display name"
              },
              "patterns": {
                "type": "array",
                "description": "Pattern list (case-insensitive contains match)",
                "items": {
                  "type": "string"
                },
                "minItems": 1
              },
              "enabled": {
                "type": "boolean",
                "default": true
              }
            }
          }
        },
        "exclude_patterns": {
          "type": "array",
          "description": "Course names to exclude (regex patterns)",
          "items": {
            "type": "string"
          }
        },
        "min_availability": {
          "type": "integer",
          "description": "Minimum available slots to notify",
          "minimum": 0,
          "default": 1
        }
      }
    },
    "notifiers": {
      "type": "object",
      "description": "Notification channel configuration",
      "properties": {
        "email": {
          "type": "object",
          "description": "Email notification settings",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "smtp_host": {
              "type": "string",
              "description": "SMTP server hostname"
            },
            "smtp_port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "use_tls": {
              "type": "boolean"
            },
            "smtp_username": {
              "type": "string"
            },
            "smtp_password_encrypted": {
              "type": "string",
              "description": "DPAPI encrypted password"
            },
            "from_address": {
              "type": "string",
              "format": "email"
            },
            "from_name": {
              "type": "string"
            },
            "recipients": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "email"
              },
              "minItems": 1
            },
            "retry_attempts": {
              "type": "integer",
              "minimum": 1
            },
            "timeout_seconds": {
              "type": "integer",
              "minimum": 5
            }
          }
        },
        "discord": {
          "type": "object",
          "description": "Discord webhook notifications",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "webhook_url": {
              "type": "string",
              "format": "uri"
            },
            "retry_attempts": {
              "type": "integer",
              "minimum": 1
            },
            "timeout_seconds": {
              "type": "integer",
              "minimum": 5
            }
          }
        },
        "windows_toast": {
          "type": "object",
          "description": "Windows Toast notification settings",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "app_id": {
              "type": "string"
            }
          }
        }
      }
    },
    "state": {
      "type": "object",
      "description": "State file configuration",
      "properties": {
        "file_path": {
          "type": "string",
          "default": "data/state.json"
        },
        "retention_days": {
          "type": "integer",
          "minimum": 1,
          "default": 30
        }
      }
    },
    "logging": {
      "type": "object",
      "description": "Logging configuration",
      "properties": {
        "log_dir": {
          "type": "string",
          "default": "data/logs"
        },
        "max_log_size_mb": {
          "type": "integer",
          "minimum": 1,
          "default": 10
        },
        "retention_days": {
          "type": "integer",
          "minimum": 1,
          "default": 30
        },
        "log_level": {
          "type": "string",
          "enum": ["TRACE", "DEBUG", "INFO", "WARN", "ERROR"],
          "default": "INFO"
        }
      }
    }
  }
}
