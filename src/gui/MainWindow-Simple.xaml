<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IPSC Kurs Watcher - Configuration"
        Width="800"
        Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <StackPanel Margin="20">
            <TextBlock Text="IPSC Kurs Watcher Configuration"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       Foreground="#2C3E50"/>

            <TabControl Margin="0,0,0,20">
                <!-- Tab 1: Monitors -->
                <TabItem Header="Monitors">
                    <StackPanel Margin="15">
                        <TextBlock Text="Active Monitors" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ListBox Height="200" Margin="0,0,0,15" Background="#ECF0F1">
                            <ListBoxItem>Shooting Store - Hauptseite (Poll: 15min)</ListBoxItem>
                        </ListBox>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Add" Width="80" Margin="0,0,5,0" Padding="5"/>
                            <Button Content="Edit" Width="80" Margin="0,0,5,0" Padding="5"/>
                            <Button Content="Delete" Width="80" Padding="5"/>
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <!-- Tab 2: Course Types -->
                <TabItem Header="Course Types">
                    <StackPanel Margin="15">
                        <TextBlock Text="Configured Course Types" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ListBox Height="200" Margin="0,0,0,15" Background="#ECF0F1">
                            <ListBoxItem>Tryout (Patterns: Tryout, Einsteiger-Kurs)</ListBoxItem>
                            <ListBoxItem>Basic Level (Patterns: Basic, Anfänger, Level 1)</ListBoxItem>
                            <ListBoxItem>Basic 2.0 (Patterns: Basic 2.0, Basic 2.x, Level 2)</ListBoxItem>
                        </ListBox>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Add" Width="80" Margin="0,0,5,0" Padding="5"/>
                            <Button Content="Edit" Width="80" Margin="0,0,5,0" Padding="5"/>
                            <Button Content="Delete" Width="80" Padding="5"/>
                        </StackPanel>
                    </StackPanel>
                </TabItem>

                <!-- Tab 3: Notifications -->
                <TabItem Header="Notifications">
                    <StackPanel Margin="15">
                        <TextBlock Text="Notification Channels" FontWeight="Bold" Margin="0,0,0,15"/>

                        <CheckBox Margin="0,0,0,10">Email (SMTP)</CheckBox>
                        <TextBlock Text="SMTP Server:" Margin="20,0,0,5" FontSize="11"/>
                        <TextBox Margin="20,0,0,10" Height="25"/>

                        <CheckBox Margin="0,0,0,10">Discord Webhook</CheckBox>
                        <TextBlock Text="Webhook URL:" Margin="20,0,0,5" FontSize="11"/>
                        <TextBox Margin="20,0,0,10" Height="25"/>

                        <CheckBox Margin="0,0,0,10">Windows Toast</CheckBox>

                        <Button Content="Test All Channels" Padding="10,5" Margin="0,20,0,0" Width="150"/>
                    </StackPanel>
                </TabItem>

                <!-- Tab 4: Scheduler -->
                <TabItem Header="Scheduler">
                    <StackPanel Margin="15">
                        <TextBlock Text="Watcher Status: Stopped" FontWeight="Bold" Margin="0,0,0,15" Foreground="#E74C3C"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Button Content="Start" Padding="10,5" Margin="0,0,5,0" Width="80"/>
                            <Button Content="Stop" Padding="10,5" Margin="0,0,5,0" Width="80"/>
                            <Button Content="Run Now" Padding="10,5" Width="80"/>
                        </StackPanel>

                        <TextBlock Text="Recent Logs:" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ListBox Height="250" Background="#2C3E50" Foreground="#ECF0F1" FontFamily="Courier New" FontSize="10">
                            <ListBoxItem>[Ready]</ListBoxItem>
                        </ListBox>
                    </StackPanel>
                </TabItem>

                <!-- Tab 5: About -->
                <TabItem Header="About">
                    <StackPanel Margin="15">
                        <TextBlock Text="IPSC Kurs Watcher" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="Version: 1.0.0" Margin="0,0,0,5" Foreground="#7F8C8D"/>
                        <TextBlock Text="Status: Production Ready" Margin="0,0,0,20" Foreground="#27AE60"/>

                        <TextBlock Text="Features:" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="✓ Multiple monitor sources" Margin="10,0,0,5" TextWrapping="Wrap"/>
                        <TextBlock Text="✓ Course type filtering" Margin="10,0,0,5" TextWrapping="Wrap"/>
                        <TextBlock Text="✓ Email notifications" Margin="10,0,0,5" TextWrapping="Wrap"/>
                        <TextBlock Text="✓ Discord webhooks" Margin="10,0,0,5" TextWrapping="Wrap"/>
                        <TextBlock Text="✓ Windows Toast notifications" Margin="10,0,0,5" TextWrapping="Wrap"/>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                <Button Content="Save Configuration" Padding="10,5" Margin="0,0,5,0" Width="150" Background="#27AE60" Foreground="White"/>
                <Button Content="Close" Padding="10,5" Width="80"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
