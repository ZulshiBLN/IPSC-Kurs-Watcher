<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IPSC Kurs Watcher - Configuration"
        Width="900"
        Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <DockPanel>
        <!-- Title Bar -->
        <Border DockPanel.Dock="Top" Background="#2C3E50" Padding="15">
            <StackPanel>
                <TextBlock Text="IPSC Kurs Watcher"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"/>
                <TextBlock Text="Configuration Management"
                           FontSize="12"
                           Foreground="#BDC3C7"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Tab Control -->
        <TabControl DockPanel.Dock="Top" Margin="10">
            <!-- Tab 1: Monitors -->
            <TabItem Header="Monitors" Padding="15,5">
                <Border Background="White" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Monitor Management"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Add, edit, or remove course monitoring sources"
                                   FontSize="11"
                                   Foreground="#7F8C8D"
                                   Margin="0,0,0,15"/>

                        <!-- Monitors List -->
                        <DataGrid Name="MonitorsGrid"
                                  Height="300"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  Margin="0,0,0,15">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding name}" Width="*"/>
                                <DataGridTextColumn Header="Provider" Binding="{Binding provider}" Width="100"/>
                                <DataGridTextColumn Header="Interval (min)" Binding="{Binding poll_interval_minutes}" Width="80"/>
                                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding enabled}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Monitor Actions -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Button Content="Add Monitor" Padding="10,5" Margin="0,0,5,0" Background="#3498DB" Foreground="White"/>
                            <Button Content="Edit Selected" Padding="10,5" Margin="0,0,5,0" Background="#2ECC71" Foreground="White"/>
                            <Button Content="Delete" Padding="10,5" Margin="0,0,5,0" Background="#E74C3C" Foreground="White"/>
                            <Button Content="Test Connection" Padding="10,5" Background="#9B59B6" Foreground="White"/>
                        </StackPanel>

                        <TextBlock Text="Monitor Status: All OK"
                                   FontSize="11"
                                   Foreground="#27AE60"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Tab 2: Filters -->
            <TabItem Header="Filters" Padding="15,5">
                <Border Background="White" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Course Type Filters"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Define and manage course type filtering rules"
                                   FontSize="11"
                                   Foreground="#7F8C8D"
                                   Margin="0,0,0,15"/>

                        <!-- Course Types List -->
                        <DataGrid Name="CourseTypesGrid"
                                  Height="300"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  Margin="0,0,0,15">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Type ID" Binding="{Binding id}" Width="100"/>
                                <DataGridTextColumn Header="Name" Binding="{Binding name}" Width="*"/>
                                <DataGridTextColumn Header="Patterns" Binding="{Binding patterns}" Width="200"/>
                                <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding enabled}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Filter Actions -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Button Content="Add Type" Padding="10,5" Margin="0,0,5,0" Background="#3498DB" Foreground="White"/>
                            <Button Content="Edit Selected" Padding="10,5" Margin="0,0,5,0" Background="#2ECC71" Foreground="White"/>
                            <Button Content="Delete" Padding="10,5" Margin="0,0,5,0" Background="#E74C3C" Foreground="White"/>
                            <Button Content="Test Filter" Padding="10,5" Background="#9B59B6" Foreground="White"/>
                        </StackPanel>

                        <TextBlock Text="Exclusion Patterns: 3 configured"
                                   FontSize="11"
                                   Foreground="#27AE60"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Tab 3: Notifications -->
            <TabItem Header="Notifications" Padding="15,5">
                <Border Background="White" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Global Notification Settings"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Configure email, Discord, and Windows Toast notifications"
                                   FontSize="11"
                                   Foreground="#7F8C8D"
                                   Margin="0,0,0,15"/>

                        <TabControl>
                            <!-- Email Tab -->
                            <TabItem Header="Email" Padding="10,3">
                                <StackPanel Padding="10">
                                    <CheckBox Content="Enable Email Notifications" Margin="0,0,0,15"/>
                                    <TextBlock Text="SMTP Server:" Margin="0,0,0,5"/>
                                    <TextBox Height="25" Margin="0,0,0,10" Padding="5"/>
                                    <TextBlock Text="Port:" Margin="0,0,0,5"/>
                                    <TextBox Height="25" Margin="0,0,0,10" Padding="5"/>
                                    <TextBlock Text="From Address:" Margin="0,0,0,5"/>
                                    <TextBox Height="25" Margin="0,0,0,10" Padding="5"/>
                                    <TextBlock Text="Recipients (one per line):" Margin="0,0,0,5"/>
                                    <TextBox Height="80" Margin="0,0,0,10" Padding="5" TextWrapping="Wrap" AcceptsReturn="True"/>
                                    <Button Content="Test Email" Padding="10,5" Background="#9B59B6" Foreground="White"/>
                                </StackPanel>
                            </TabItem>

                            <!-- Discord Tab -->
                            <TabItem Header="Discord" Padding="10,3">
                                <StackPanel Padding="10">
                                    <CheckBox Content="Enable Discord Notifications" Margin="0,0,0,15"/>
                                    <TextBlock Text="Webhook URL:" Margin="0,0,0,5"/>
                                    <TextBox Height="25" Margin="0,0,0,10" Padding="5"/>
                                    <TextBlock Text="Embed Color (hex):" Margin="0,0,0,5"/>
                                    <TextBox Height="25" Margin="0,0,0,15" Padding="5" Text="3447003"/>
                                    <Button Content="Test Discord" Padding="10,5" Background="#9B59B6" Foreground="White"/>
                                </StackPanel>
                            </TabItem>

                            <!-- Toast Tab -->
                            <TabItem Header="Windows Toast" Padding="10,3">
                                <StackPanel Padding="10">
                                    <CheckBox Content="Enable Windows Toast Notifications" Margin="0,0,0,15"/>
                                    <TextBlock Text="Duration:" Margin="0,0,0,5"/>
                                    <ComboBox Height="25" Margin="0,0,0,15" Padding="5">
                                        <ComboBoxItem>Short</ComboBoxItem>
                                        <ComboBoxItem>Long</ComboBoxItem>
                                    </ComboBox>
                                    <Button Content="Test Toast" Padding="10,5" Background="#9B59B6" Foreground="White"/>
                                </StackPanel>
                            </TabItem>
                        </TabControl>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Tab 4: Scheduler -->
            <TabItem Header="Scheduler" Padding="15,5">
                <Border Background="White" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Scheduler Control"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Start, stop, and monitor the watcher service"
                                   FontSize="11"
                                   Foreground="#7F8C8D"
                                   Margin="0,0,0,15"/>

                        <!-- Status -->
                        <Border Background="#ECF0F1" Padding="15" Margin="0,0,0,15" CornerRadius="3">
                            <StackPanel>
                                <TextBlock Text="Current Status:" FontWeight="Bold"/>
                                <TextBlock Text="Running" Foreground="#27AE60" FontSize="14" Margin="0,5,0,0"/>
                                <TextBlock Text="Last Run: 2026-07-03 14:30:45" FontSize="11" Foreground="#7F8C8D" Margin="0,5,0,0"/>
                                <TextBlock Text="Next Run: 2026-07-03 14:45:00" FontSize="11" Foreground="#7F8C8D"/>
                            </StackPanel>
                        </Border>

                        <!-- Controls -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <Button Content="Start Watcher" Padding="10,5" Margin="0,0,5,0" Background="#27AE60" Foreground="White"/>
                            <Button Content="Stop Watcher" Padding="10,5" Margin="0,0,5,0" Background="#E74C3C" Foreground="White"/>
                            <Button Content="Run Now" Padding="10,5" Background="#3498DB" Foreground="White"/>
                        </StackPanel>

                        <!-- Log Viewer -->
                        <TextBlock Text="Recent Logs:" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ListBox Height="200" Background="#2C3E50" Foreground="#ECF0F1" Padding="10" FontFamily="Courier New" FontSize="10">
                            <ListBoxItem>[14:30:45] [INFO] Monitor started: shooting-store</ListBoxItem>
                            <ListBoxItem>[14:30:46] [INFO] Found 5 courses</ListBoxItem>
                            <ListBoxItem>[14:30:47] [INFO] Filter passed 3 courses</ListBoxItem>
                            <ListBoxItem>[14:30:48] [INFO] Email notification sent</ListBoxItem>
                            <ListBoxItem>[14:30:49] [INFO] Cycle complete</ListBoxItem>
                        </ListBox>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Tab 5: Data -->
            <TabItem Header="Data" Padding="15,5">
                <Border Background="White" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Data Management"
                                   FontSize="14"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>
                        <TextBlock Text="Export, import, and backup configuration and state"
                                   FontSize="11"
                                   Foreground="#7F8C8D"
                                   Margin="0,0,0,15"/>

                        <!-- Config Operations -->
                        <TextBlock Text="Configuration:" FontWeight="Bold" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Button Content="Export Config" Padding="10,5" Margin="0,0,5,0" Background="#3498DB" Foreground="White"/>
                            <Button Content="Import Config" Padding="10,5" Margin="0,0,5,0" Background="#2ECC71" Foreground="White"/>
                            <Button Content="Reset to Default" Padding="10,5" Background="#E67E22" Foreground="White"/>
                        </StackPanel>

                        <!-- State Operations -->
                        <TextBlock Text="State &amp; History:" FontWeight="Bold" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                            <Button Content="View Backups" Padding="10,5" Margin="0,0,5,0" Background="#9B59B6" Foreground="White"/>
                            <Button Content="Clear History" Padding="10,5" Margin="0,0,5,0" Background="#E74C3C" Foreground="White"/>
                        </StackPanel>

                        <!-- File Info -->
                        <TextBlock Text="File Locations:" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="Config: config/config.json" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBlock Text="State: data/state.json" FontSize="11" Foreground="#7F8C8D" Margin="0,0,0,3"/>
                        <TextBlock Text="Logs: data/logs/" FontSize="11" Foreground="#7F8C8D"/>
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar DockPanel.Dock="Bottom" Background="#34495E" Foreground="White" Padding="10">
            <TextBlock Text="Ready" Margin="0,0,20,0"/>
            <TextBlock Text="Watcher: Running"/>
        </StatusBar>
    </DockPanel>
</Window>
